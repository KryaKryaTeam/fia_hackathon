{
  "targets": {
    "build-container": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker buildx build -t ghcr.io/kryakryateam/fia_hackathon/backend:latest -f ./apps/backend/Dockerfile.nx ."
        ]
      }
    },
    "container-push": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker push ghcr.io/kryakryateam/fia_hackathon/backend:latest"
        ]
      }
    }
  }
}
