{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "types": ["jest", "node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDirs": ["src", "."],
    "target": "es2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "composite": false,
    "incremental": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "strictPropertyInitialization": false,
    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
